# PostgreSQL — must match a real role/password on your server (see docs/prisma.md)
DATABASE_URL="postgresql://user:all9s_dev_password@localhost:5432/all9ssolutions?schema=public"

# Supabase: transaction pooler for the app; session pooler for Prisma CLI (migrate, studio)
# DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?uselibpqcompat=true&sslmode=require&pgbouncer=true"
# PG_SSL_REJECT_UNAUTHORIZED=true  # optional: strict TLS verify (default true in production)
# DIRECT_URL="postgres://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?uselibpqcompat=true&sslmode=require"
# If db.[project-ref].supabase.co:5432 works on your network, you can use that URI instead of the session pooler.

# Consultation form (defaults to protected Next.js API route)
# NEXT_PUBLIC_CONSULTATION_FORM_ENDPOINT="/api/consultation"

# Confirmation email to new submitters and portal agreement copies (Resend — https://resend.com)
# RESEND_API_KEY="re_..."
# CONSULTATION_CONFIRMATION_FROM="all9s Solutions <hello@all9ssolutions.com>"
# CONSULTATION_REPLY_TO="hello@all9ssolutions.com"
# Resend webhook signing secret — required for POST /api/webhooks/resend (email.bounced, email.delivered)
# RESEND_WEBHOOK_SECRET="whsec_..."

# Portal password reset links (production: your public site URL)
# PORTAL_APP_URL="https://www.all9ssolutions.com"

# Optional: forward submission to PHP/internal handler
# CONSULTATION_MAIL_FORWARD_URL="https://your-domain.com/php/send-consultation.php"
# CONSULTATION_API_SECRET="your-long-random-secret"

# Cloudflare Turnstile is disabled — do not set NEXT_PUBLIC_TURNSTILE_SITE_KEY or TURNSTILE_SECRET_KEY

# Consultation API rate limits are disabled automatically in development (npm run dev).
# For local production builds, optionally set:
# DISABLE_CONSULTATION_RATE_LIMIT=true

# Client portal sessions (required in production; min 32 characters)
# PORTAL_SESSION_SECRET="generate-a-long-random-secret-here"

# Supabase (Project → Settings → API)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"   # Realtime for portal Messages
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # Server: portal document uploads (Storage)
# PORTAL_UPLOAD_BUCKET="portal-uploads"   # private bucket — see docs/supabase-portal-storage.md

# Portal API rate limits are disabled automatically in development (npm run dev).
# DISABLE_PORTAL_RATE_LIMIT=true

# Seed a dev portal user (email stored on ConsultationRequest): npm run db:seed-portal
# PORTAL_SEED_EMAIL="client@example.com"
# PORTAL_SEED_PASSWORD="TempPass123!"
# PORTAL_SEED_NAME="Portal Test Client"

# Create a portal user linked by email (password TempPass123!):
# npm run db:create-portal-user -- --email=client@example.com
# PORTAL_USER_EMAIL="client@example.com"

# Provision portal users from consultation submissions:
# npm run db:provision-portal-users
# npm run db:provision-portal-users -- --dry-run
# PORTAL_PROVISION_PASSWORD="TempPass123!"  # optional fixed temp password for new users (dev only)

# Insert ConsultationRequest + linked PortalUser:
# npm run db:enter-consultation-portal
# npm run db:enter-consultation-portal -- --step=consultation
# npm run db:enter-consultation-portal -- --step=portal --consultation-id=YOUR_ID
# TEST_CONSULTATION_EMAIL="test.client@example.com"
# TEST_PORTAL_PASSWORD="TempPass123!"

# Google Analytics 4 (GA4)
# Set to enable analytics. Leave commented out/blank to disable.
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
